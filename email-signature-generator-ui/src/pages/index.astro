---
import '../styles/global.css';
---

<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Email Signature Generator</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js" is:inline></script>
</head>
<body>
  <div class="container">
    <header>
      <h1>📧 Email Signature Generator</h1>
      <p>Generate personalised signatures from a CSV — or for a single user.</p>
    </header>

    <!-- Mode switch -->
    <div class="mode-switch" role="tablist" aria-label="Generation mode">
      <label class="mode-option">
        <input type="radio" name="mode" value="csv" checked>
        <span>
          <svg class="mode-icon" viewBox="0 0 24 24" width="16" height="16" fill="none"
               stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
               aria-hidden="true">
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
            <polyline points="14 2 14 8 20 8"/>
            <line x1="8" y1="13" x2="16" y2="13"/>
            <line x1="8" y1="17" x2="16" y2="17"/>
          </svg>
          CSV Upload
        </span>
      </label>
      <label class="mode-option">
        <input type="radio" name="mode" value="single">
        <span>
          <svg class="mode-icon" viewBox="0 0 24 24" width="16" height="16" fill="none"
               stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
               aria-hidden="true">
            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
            <circle cx="12" cy="7" r="4"/>
          </svg>
          Single User
        </span>
      </label>
    </div>

    <!-- Steps indicator (shared) -->
    <div class="steps">
      <div class="step active" id="step-1"></div>
      <div class="step" id="step-2"></div>
      <div class="step" id="step-3"></div>
    </div>

    <!-- ─── CSV MODE ─────────────────────────────────────────────── -->
    <div class="card" id="card-upload" data-mode="csv">
      <h2>1. Upload Staff CSV</h2>
      <div class="upload-area" id="drop-zone">
        <div class="icon">📄</div>
        <strong>Drop one or more CSV files here</strong>
        <p>or click to browse — each file must include a header row</p>
        <input type="file" id="csv-input" accept=".csv" multiple hidden>
      </div>
      <div id="file-list" class="file-list" style="display:none;"></div>
      <div class="messages" id="csv-messages"></div>
    </div>

    <!-- ─── SINGLE USER MODE ─────────────────────────────────────── -->
    <div class="card" id="card-form" data-mode="single">
      <h2>1. User Details</h2>
      <form id="single-form" class="single-form" novalidate>
        <div class="field">
          <label for="single-FirstName">First name <span class="req">*</span></label>
          <input id="single-FirstName" name="FirstName" type="text" autocomplete="given-name" required>
          <div class="field-error" id="err-FirstName"></div>
        </div>
        <div class="field">
          <label for="single-LastName">Last name <span class="req">*</span></label>
          <input id="single-LastName" name="LastName" type="text" autocomplete="family-name" required>
          <div class="field-error" id="err-LastName"></div>
        </div>
        <div class="field">
          <label for="single-Mail">Email <span class="req">*</span></label>
          <input id="single-Mail" name="Mail" type="email" autocomplete="email" required>
          <div class="field-error" id="err-Mail"></div>
        </div>
        <div class="field">
          <label for="single-Title">Title <span class="req">*</span></label>
          <input id="single-Title" name="Title" type="text" autocomplete="organization-title" required>
          <div class="field-error" id="err-Title"></div>
        </div>
        <div class="field">
          <label for="single-MobilePhone">Mobile phone <span class="opt">(optional)</span></label>
          <input id="single-MobilePhone" name="MobilePhone" type="tel" autocomplete="tel">
          <div class="field-error" id="err-MobilePhone"></div>
        </div>
      </form>
    </div>

    <!-- ─── SHARED: Template + Preview ───────────────────────────── -->
    <div class="card" id="card-template">
      <h2>2. Signature Template</h2>
      <select id="template-select">
        <option value="/templates/signature-template.html">MNS Default Template</option>
      </select>
      <div class="preview-frame" id="template-preview">
        <iframe id="preview-iframe" title="Template Preview" scrolling="no"></iframe>
      </div>
    </div>

    <!-- ─── CSV MODE: Generate ───────────────────────────────────── -->
    <div class="card" id="card-generate-csv" data-mode="csv">
      <h2>3. Generate Signatures</h2>
      <p style="font-size:0.875rem; color:var(--color-muted); margin-bottom:16px;">
        Detected columns will map to placeholders in the template.
      </p>
      <div id="column-mapping" style="font-size:0.8rem; margin-bottom:16px;"></div>
      <button class="btn btn-primary" id="csv-btn-generate" disabled>
        ⚡ Generate ZIP
      </button>
      <div class="progress-container" id="csv-progress-container">
        <div class="progress-bar-bg">
          <div class="progress-bar-fill" id="csv-progress-fill"></div>
        </div>
        <div class="progress-text" id="csv-progress-text">0 / 0</div>
      </div>
      <div class="messages" id="csv-gen-messages"></div>
    </div>

    <!-- ─── CSV MODE: Result ─────────────────────────────────────── -->
    <div class="card result-section" id="csv-card-result" data-mode="csv">
      <div class="count" id="csv-result-count">0</div>
      <div class="label">signatures generated</div>
      <button class="btn btn-secondary" id="csv-btn-download">
        📦 Download ZIP
      </button>
    </div>

    <!-- ─── SINGLE MODE: Generate ────────────────────────────────── -->
    <div class="card" id="card-generate-single" data-mode="single">
      <h2>3. Generate Signature</h2>
      <p style="font-size:0.875rem; color:var(--color-muted); margin-bottom:16px;">
        The HTML file (and the ZIP) will be named after the user's email address.
      </p>
      <button class="btn btn-primary" id="single-btn-generate" disabled>
        ⚡ Generate Signature ZIP
      </button>
      <div class="messages" id="single-gen-messages"></div>
    </div>

    <!-- ─── SINGLE MODE: Result ──────────────────────────────────── -->
    <div class="card result-section" id="single-card-result" data-mode="single">
      <div class="label" id="single-result-label">Signature ready</div>
      <button class="btn btn-secondary" id="single-btn-download">
        📦 Download ZIP
      </button>
    </div>
  </div>

  <script>
    import '../lib/app';
  </script>
</body>
</html>

